        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nclass User {\n  -userId: int\n  -username: String\n  -email: String\n  -password: String\n  +register()\n  +login()\n  +logout()\n}\n\nclass Car {\n  -carId: int\n  -brand: String\n  -model: String\n  -year: int\n  -licensePlate: String\n  -available: boolean\n  +rent()\n  +returnCar()\n}\n\nclass RentalTransaction {\n  -transactionId: int\n  -user: User\n  -car: Car\n  -startDate: Date\n  -endDate: Date\n  -totalCost: double\n  +calculateTotalCost(): double\n}\n\nclass PaymentGateway {\n  +processPayment(amount: double, user: User): boolean\n}\n\nclass P2PCarRentingSystem {\n  -users: List&lt;User&gt;\n  -cars: List&lt;Car&gt;\n  -rentalTransactions: List&lt;RentalTransaction&gt;\n  +addUser(user: User)\n  +addCar(car: Car)\n  +rentCar(user: User, car: Car, startDate: Date, endDate: Date): RentalTransaction\n  +returnCar(transactionId: int)\n}\n\nUser -- RentalTransaction : makes\nCar -- RentalTransaction : is rented to\nUser -- P2PCarRentingSystem : uses\nCar -- P2PCarRentingSystem : manages\nRentalTransaction -- P2PCarRentingSystem : records\nUser -- PaymentGateway : uses\nRentalTransaction -- PaymentGateway : initiates payment\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="zSlt-5jsIsF8fF3iLb-Z-2">
