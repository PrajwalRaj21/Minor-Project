            <script type="text/javascript">
                zE('webWidget', 'hide');
                zE('webWidget:on', 'close', () => {
                    zE('webWidget', 'hide')
                });
                zE('webWidget:on', 'open', () => {
                    // Hide Zendesk Logo from the Live Chat
                    setTimeout(function(){
                        var ifEles = document.getElementsByTagName("iframe");
                        for (var x=0; x < ifEles.length; x++) {
                            if (ifEles[x].id === "webWidget") {
                                var zdDoc = ifEles[x].contentWindow ? ifEles[x].contentWindow.document : ifEles[x].contentDocument;
                                var els = zdDoc.querySelectorAll("a.sc-1slnzzg-0.kkUEer");
                                if (els.length == 1) {
                                    els[0].style.visibility="hidden";
                                }
                            }
                        };
                    }, 500);
                });
            </script>
            <script type="text/javascript">
